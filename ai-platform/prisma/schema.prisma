generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // "admin" or "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  records   Record[]
}

model Record {
  id         Int      @id @default(autoincrement())
  moduleId   String   // e.g., "weather-crop-api", "biosim"
  moduleType String   // "simulator" | "platform"
  title      String
  inputData  String   // JSON string
  outputData String   // JSON string
  memo       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User?    @relation(fields: [userId], references: [id])
  userId     String?

  @@index([moduleId])
  @@index([moduleType])
  @@index([createdAt])
  @@index([userId])
}
